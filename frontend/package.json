{
  "name": "nexus-ultra",
  "private": true,
  "version": "1.0.1",
  "description": "AI-powered cybersecurity platform — 12 elite agents, Groq/Gemini free AI, Kali Docker, OSINT",
  "author": "NEXUS ULTRA",
  "repository": {
    "type": "git",
    "url": "https://github.com/flippits/nexus-ultra"
  },
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "start": "lsof -ti:5173,8765 | xargs kill -9 2>/dev/null; concurrently \"npm run dev\" \"wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
    "build:mac": "npm run build && electron-builder --mac --publish never",
    "build:win": "npm run build && electron-builder --win --publish never",
    "build:linux": "npm run build && electron-builder --linux --publish never",
    "build:all": "npm run build && electron-builder --mac --win --publish never",
    "build:app": "npm run build && electron-builder --mac --publish never",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.nexus.ultra",
    "productName": "NEXUS ULTRA",
    "copyright": "Copyright 2025 NEXUS ULTRA",
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NEXUS ULTRA"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Security"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.cjs",
      "public/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo",
          "!**/.DS_Store",
          "!**/*.db",
          "!**/*.txt",
          "!**/.env",
          "!.git/**",
          "!nexus_backend.spec",
          "!build/**"
        ]
      },
      {
        "from": "bundled-backend",
        "to": "backend/nexus_backend",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "output": "../dist-app",
      "buildResources": "public"
    }
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.16.1",
    "cytoscape": "^3.33.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
